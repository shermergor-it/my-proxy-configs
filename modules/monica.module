#!name=Monica AI Proxy
#!desc=Правила для работы Monica.im через прокси

[Rule]
# Основные домены сервиса
DOMAIN-SUFFIX,monica.im,PROXY
DOMAIN-SUFFIX,monicahq.com,PROXY

# API и сервисы авторизации (специфические для Monica)
DOMAIN-KEYWORD,monica-pa,PROXY
DOMAIN-SUFFIX,monica-api.com,PROXY

# Статика и дополнительные ресурсы (если используются расширения)
DOMAIN-SUFFIX,monica-static.com,PROXY

# Поддержка работы через инфраструктуру Google (иногда требуется для API)
DOMAIN-SUFFIX,monica-pa.clients6.google.com,PROXY

# Если используете расширение в браузере, оно может обращаться к этим эндпоинтам
DOMAIN-SUFFIX,api.monica.im,PROXY
